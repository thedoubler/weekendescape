# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored — never commit real secrets to the repo.

# Kiwi.com Tequila API key (required) — https://tequila.kiwi.com/portal/login
TEQUILA_API_KEY=

# Currency for prices (optional, default: EUR)
WEEKEND_CURRENCY=EUR

# Booking.com affiliate id (optional) — set once you join their partner
# program to monetize the per-card hotel links.
NEXT_PUBLIC_BOOKING_AID=

# Unsplash Access Key (free) for destination hero images — optional; cards degrade gracefully without it.
# Get one at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
